{
  "name": "mini-drop",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:agent": "tsx watch server/agent/index.ts",
    "dev:client": "vite",
    "demo": "npm run demo:up && npm run demo:wait && npm run demo:pid",
    "demo:up": "docker compose -f docker-compose.yml -f docker-compose.ebpf-demo.yml up --build -d mini-drop-server mini-drop-agent mini-drop-demo-target",
    "demo:wait": "node scripts/demo-control.mjs wait",
    "demo:pid": "node scripts/demo-control.mjs pid",
    "demo:load": "node scripts/demo-control.mjs load",
    "demo:load:stop": "node scripts/demo-control.mjs load-stop",
    "demo:io": "docker compose -f docker-compose.yml -f docker-compose.ebpf-demo.yml --profile jitter run --rm io-jitter",
    "demo:sched": "docker compose -f docker-compose.yml -f docker-compose.ebpf-demo.yml --profile jitter run --rm sched-jitter",
    "demo:smoke": "docker compose -f docker-compose.yml -f docker-compose.ebpf-demo.yml exec mini-drop-server npm run smoke:api && docker compose -f docker-compose.yml -f docker-compose.ebpf-demo.yml exec mini-drop-server npm run smoke:ebpf-linux",
    "demo:down": "docker compose -f docker-compose.yml -f docker-compose.ebpf-demo.yml down",
    "build": "vite build && tsc -p tsconfig.server.json",
    "agent:start": "tsx server/agent/index.ts",
    "start": "node -e \"process.env.NODE_ENV='production'; import('./dist/server/server/index.js')\"",
    "start:prod": "npm run start",
    "smoke:api": "node scripts/smoke-api.mjs",
    "smoke:create-task": "node scripts/smoke-create-task.mjs",
    "smoke:repeat-task": "node scripts/smoke-repeat-task.mjs",
    "smoke:ebpf-linux": "node scripts/smoke-ebpf-linux.mjs",
    "smoke:linux-real-process-attach": "node scripts/smoke-linux-real-process-attach.mjs",
    "smoke:perf-linux": "node scripts/smoke-perf-linux.mjs",
    "smoke:reasoner-tool-grounded": "node scripts/smoke-reasoner-tool-grounded.mjs",
    "smoke:process-target": "node scripts/smoke-compare-trend.mjs --pid-target-only",
    "smoke:compare-trend": "node scripts/smoke-compare-trend.mjs",
    "smoke:continuous-profile": "node scripts/smoke-continuous-profile.mjs",
    "validate:offline-agent": "tsx scripts/validate-offline-agent.mjs",
    "validate:local": "npm run typecheck && npm run test && npm run build",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.server.json",
    "test": "node --import ./tests/setup-test-env.mjs --import tsx --test --test-concurrency=1 tests/*.ts"
  },
  "dependencies": {
    "express": "^4.21.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "^22.15.21",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.5.0",
    "concurrently": "^9.2.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^5.4.19"
  },
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": ""
}
